<resources>

    <style name="Base.Theme.TheColor" parent="Base.V23.Theme.TheColor" />

    <style name="Base.V23.Theme.TheColor" parent="Base.Theme.Material">

        <item name="android:navigationBarColor">?android:attr/colorBackground</item>

        <!-- colors theme -->
        <item name="colorPrimary">@color/violet</item>
        <item name="colorPrimaryVariant">@color/purple</item>
        <item name="colorSecondary">@color/coral</item>
        <item name="colorSecondaryVariant">?attr/colorDebug</item>
        <item name="colorSurface">@color/indigo_dark</item>
        <item name="colorError">@color/cinnamon_satin</item>

        <!-- colors on -->
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnError">@color/black</item>

        <!-- colors background -->
        <item name="android:colorBackground">@color/cod_gray</item>
        <item name="android:colorBackgroundFloating">@color/black</item>

    </style>

</resources>