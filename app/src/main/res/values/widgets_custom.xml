<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Widget styles, used in specific places and not associated with application themes.
        Preserve alphabetical order.
    -->

    <!-- region Button -->

    <style name="Widget.Button.Icon" parent="Widget.Material3.Button.TextButton.Icon">
        <item name="iconPadding">0dp</item>
        <item name="android:padding">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
    </style>

    <style name="Widget.Button.Outlined.OnBackground" parent="Widget.TheColor.Button.Outlined">
        <item name="materialThemeOverlay">@style/MaterialThemeOverlay.Button.Outlined.OnBackground
        </item>
        <item name="strokeColor">?attr/colorOnBackground</item>
    </style>

    <style name="Widget.Button.Text.OnBackground" parent="Widget.TheColor.Button.Text">
        <item name="materialThemeOverlay">@style/MaterialThemeOverlay.Button.Text.OnBackground
        </item>
    </style>

    <style name="Widget.Button.Tonal.SurfaceVariant" parent="Widget.TheColor.Button.Tonal">
        <item name="materialThemeOverlay">@style/MaterialThemeOverlay.Button.Tonal.SurfaceVariant
        </item>
    </style>

    <!-- endregion -->

    <style name="Widget.Chip.Outlined" parent="Widget.Material3.Chip.Suggestion">
        <item name="materialThemeOverlay">@style/MaterialThemeOverlay.Chip.Outlined</item>
    </style>

    <style name="Widget.MaterialDivider.Insets" parent="Widget.TheColor.MaterialDivider">
        <item name="dividerInsetStart">@dimen/offset_content_horizontal</item>
        <item name="dividerInsetEnd">@dimen/offset_content_horizontal</item>
    </style>

    <!-- region TextView -->

    <!-- solution to override any specified textApearance's fontFamily -->
    <style name="Widget.TextView.Value" parent="">
        <item name="fontFamily">sans-serif</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Widget.TextView.ListItem" parent="Widget.TheColor.TextView">
        <item name="android:paddingTop">@dimen/offset_content_default</item>
        <item name="android:paddingBottom">@dimen/offset_content_default</item>
        <item name="android:paddingStart">@dimen/offset_content_horizontal</item>
        <item name="android:paddingEnd">@dimen/offset_content_horizontal</item>
        <item name="android:textAppearance">?attr/textAppearanceBodyLarge</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

    <!-- endregion -->

</resources>